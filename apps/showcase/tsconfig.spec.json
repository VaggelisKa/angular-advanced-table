/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../../out-tsc/apps/showcase-spec",
    "paths": {
      "ng-advanced-table": ["../../libs/ng-advanced-table/src/public-api.ts"],
      "ng-advanced-table-locales": [
        "../../libs/ng-advanced-table-locales/src/public-api.ts"
      ],
      "ng-advanced-table-types": [
        "../../libs/ng-advanced-table-types/src/public-api.ts"
      ],
      "ng-advanced-table-ui": ["../../libs/ng-advanced-table-ui/src/public-api.ts"],
      "ng-advanced-table-utils": [
        "../../libs/ng-advanced-table-utils/src/public-api.ts"
      ]
    },
    "types": ["vitest/globals"]
  },
  "include": [
    "src/**/*.d.ts",
    "src/**/*.spec.ts",
    "../../libs/ng-advanced-table/src/**/*.ts",
    "../../libs/ng-advanced-table-locales/src/**/*.ts",
    "../../libs/ng-advanced-table-types/src/**/*.ts",
    "../../libs/ng-advanced-table-ui/src/**/*.ts",
    "../../libs/ng-advanced-table-utils/src/**/*.ts"
  ],
  "exclude": [
    "../../libs/**/*.spec.ts"
  ]
}
