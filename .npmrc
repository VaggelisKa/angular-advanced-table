# Use hoisted node-linker to keep a single node_modules at the workspace root.
# Nx/Angular and the manifest-less apps/showcase resolve from the root tree.
node-linker=hoisted

# Link local workspace packages for workspace ranges (e.g. apps/showcase's
# "ng-advanced-table": "workspace:*" dep). pnpm 10 defaults this to false, which
# would otherwise resolve the published tarball instead of local source.
link-workspace-packages=true

# Automatically install peer dependencies
auto-install-peers=true

# Silence peer dependency warnings
strict-peer-dependencies=false

# Enforce Node.js engine checks
engine-strict=true
