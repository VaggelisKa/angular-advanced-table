{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": ["default", "!{projectRoot}/**/*.spec.ts", "!{projectRoot}/tsconfig.spec.json", "!{projectRoot}/eslint.config.mjs"],
    "sharedGlobals": []
  },
  "plugins": [
    {
      "plugin": "@nx/eslint/plugin",
      "options": {
        "targetName": "lint"
      }
    }
  ],
  "targetDefaults": {
    "build": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    },
    "serve": {
      "dependsOn": ["^build"]
    },
    "test": {
      "cache": true,
      "inputs": ["default", "^production"]
    },
    "e2e": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["default", "^production"]
    },
    "nx-release-publish": {
      "dependsOn": ["build"]
    }
  },
  "release": {
    "projects": ["ng-advanced-table", "ng-advanced-table-ui", "ng-advanced-table-utils", "ng-advanced-table-locales"],
    "projectsRelationship": "independent",
    "versionPlans": true,
    "releaseTag": {
      "pattern": "{projectName}@{version}"
    },
    "changelog": {
      "workspaceChangelog": false,
      "projectChangelogs": {
        "renderOptions": {
          "authors": false
        }
      }
    },
    "git": {
      "commitMessage": "chore(release): publish"
    }
  },
  "analytics": true
}
