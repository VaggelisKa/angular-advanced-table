{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": [
      "default",
      "!{projectRoot}/**/*.spec.ts",
      "!{projectRoot}/tsconfig.spec.json",
      "!{projectRoot}/eslint.config.mjs",
      "!{projectRoot}/stylelint.config.mjs"
    ],
    "sharedGlobals": []
  },
  "plugins": [
    {
      "plugin": "@nx/eslint/plugin",
      "options": {
        "targetName": "lint"
      }
    },
    {
      "plugin": "nx-stylelint/plugin",
      "options": {
        "targetName": "stylelint",
        "extensions": ["css"]
      }
    },
    {
      "plugin": "@nx/playwright/plugin",
      "options": {
        "targetName": "e2e",
        "ciTargetName": "e2e-ci"
      }
    }
  ],
  "targetDefaults": {
    "build": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    },
    "test": {
      "cache": true,
      "inputs": ["default", "^production"],
      "executor": "@angular/build:unit-test"
    },
    "stylelint": {
      "cache": true,
      "inputs": ["default", "^production"],
      "options": {
        "lintFilePatterns": ["{projectRoot}/**/*.css"]
      }
    },
    "e2e": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["default", "^production"]
    },
    "strip-nx": {
      "dependsOn": ["build"],
      "options": {
        "command": "node tools/strip-nx-manifest.mjs dist/{projectRoot}"
      }
    },
    "nx-release-publish": {
      "dependsOn": ["build", "strip-nx"],
      "options": {
        "packageRoot": "dist/{projectRoot}",
        "access": "public"
      }
    }
  },
  "release": {
    "projects": ["ng-advanced-table"],
    "versionPlans": true,
    "changelog": {
      "workspaceChangelog": false,
      "projectChangelogs": {
        "renderOptions": {
          "authors": false
        }
      }
    },
    "git": {
      "commitMessage": "chore(release): publish"
    }
  },
  "analytics": true
}
