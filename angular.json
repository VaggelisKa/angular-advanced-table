{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": "30bb135d-e588-4678-a32a-ba61bf3fd5ef"
  },
  "newProjectRoot": "libs",
  "projects": {
    "showcase": {
      "projectType": "application",
      "schematics": {},
      "root": "apps/showcase",
      "sourceRoot": "apps/showcase/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "outputs": ["{options.outputPath}"],
          "options": {
            "browser": "apps/showcase/src/main.ts",
            "tsConfig": "apps/showcase/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": ["apps/showcase/src/styles.css"]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "50kB",
                  "maximumError": "50kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "showcase:build:production"
            },
            "development": {
              "buildTarget": "showcase:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "apps/showcase/tsconfig.spec.json"
          }
        }
      }
    },
    "ng-advanced-table": {
      "projectType": "library",
      "root": "libs/ng-advanced-table",
      "sourceRoot": "libs/ng-advanced-table/src",
      "prefix": "nat",
      "architect": {
        "build": {
          "builder": "@nx/angular:package",
          "outputs": ["{workspaceRoot}/dist/libs/ng-advanced-table"],
          "options": {
            "project": "libs/ng-advanced-table/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "libs/ng-advanced-table/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "libs/ng-advanced-table/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test-build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "libs/ng-advanced-table/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "libs/ng-advanced-table/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "libs/ng-advanced-table/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "buildTarget": "ng-advanced-table:test-build:development",
            "tsConfig": "libs/ng-advanced-table/tsconfig.spec.json"
          }
        },
        "nx-release-publish": {
          "executor": "@nx/js:release-publish",
          "dependsOn": ["build"],
          "options": {
            "packageRoot": "dist/libs/ng-advanced-table",
            "access": "public"
          }
        }
      }
    },
    "ng-advanced-table-utils": {
      "projectType": "library",
      "root": "libs/ng-advanced-table-utils",
      "sourceRoot": "libs/ng-advanced-table-utils/src",
      "prefix": "nat",
      "architect": {
        "build": {
          "builder": "@nx/angular:package",
          "outputs": ["{workspaceRoot}/dist/libs/ng-advanced-table-utils"],
          "options": {
            "project": "libs/ng-advanced-table-utils/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "libs/ng-advanced-table-utils/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "libs/ng-advanced-table-utils/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test-build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "libs/ng-advanced-table-utils/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "libs/ng-advanced-table-utils/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "libs/ng-advanced-table-utils/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "buildTarget": "ng-advanced-table-utils:test-build:development",
            "tsConfig": "libs/ng-advanced-table-utils/tsconfig.spec.json"
          }
        },
        "nx-release-publish": {
          "executor": "@nx/js:release-publish",
          "dependsOn": ["build"],
          "options": {
            "packageRoot": "dist/libs/ng-advanced-table-utils",
            "access": "public"
          }
        }
      }
    },
    "ng-advanced-table-ui": {
      "projectType": "library",
      "root": "libs/ng-advanced-table-ui",
      "sourceRoot": "libs/ng-advanced-table-ui/src",
      "prefix": "nat",
      "architect": {
        "build": {
          "builder": "@nx/angular:package",
          "outputs": ["{workspaceRoot}/dist/libs/ng-advanced-table-ui"],
          "options": {
            "project": "libs/ng-advanced-table-ui/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "libs/ng-advanced-table-ui/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "libs/ng-advanced-table-ui/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test-build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "libs/ng-advanced-table-ui/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "libs/ng-advanced-table-ui/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "libs/ng-advanced-table-ui/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "buildTarget": "ng-advanced-table-ui:test-build:development",
            "tsConfig": "libs/ng-advanced-table-ui/tsconfig.spec.json"
          }
        },
        "nx-release-publish": {
          "executor": "@nx/js:release-publish",
          "dependsOn": ["build"],
          "options": {
            "packageRoot": "dist/libs/ng-advanced-table-ui",
            "access": "public"
          }
        }
      }
    }
  }
}
