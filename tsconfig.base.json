/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
/* Shared base. Every project's tsconfig.json extends this; the root tsconfig.json is a solution file that references each project. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "paths": {
      "ng-advanced-table": ["./libs/ng-advanced-table/src/public-api.ts", "./dist/libs/ng-advanced-table"],
      "ng-advanced-table-locales": ["./libs/ng-advanced-table-locales/src/public-api.ts", "./dist/libs/ng-advanced-table-locales"],
      "ng-advanced-table-types": ["./libs/ng-advanced-table-types/src/public-api.ts"],
      "ng-advanced-table-ui": ["./libs/ng-advanced-table-ui/src/public-api.ts", "./dist/libs/ng-advanced-table-ui"],
      "ng-advanced-table-utils": ["./libs/ng-advanced-table-utils/src/public-api.ts", "./dist/libs/ng-advanced-table-utils"]
    },
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "dom"],
    "noUnusedLocals": true,
    "verbatimModuleSyntax": true
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  }
}
