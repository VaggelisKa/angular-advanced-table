{
  "name": "angular-advanced-table",
  "version": "0.0.0",
  "description": "Workspace for the ng-advanced-table Angular libraries and showcase application.",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "nx": "nx",
    "start": "nx serve showcase",
    "build": "nx build showcase",
    "build:showcase": "nx build showcase",
    "build:packages": "nx run-many -t build -p ng-advanced-table,ng-advanced-table-ui,ng-advanced-table-utils,ng-advanced-table-locales",
    "watch": "nx build showcase --watch --configuration development",
    "test": "nx test showcase",
    "test:packages": "nx run-many -t test -p ng-advanced-table,ng-advanced-table-ui,ng-advanced-table-utils,ng-advanced-table-locales",
    "e2e": "playwright test -c e2e",
    "release:check": "nx release plan:check --base=${NX_BASE:-main} --head=${NX_HEAD:-HEAD} && nx release --dry-run",
    "release": "nx release",
    "pack:dry-run": "npm pack --dry-run ./dist/libs/ng-advanced-table && npm pack --dry-run ./dist/libs/ng-advanced-table-ui && npm pack --dry-run ./dist/libs/ng-advanced-table-utils && npm pack --dry-run ./dist/libs/ng-advanced-table-locales",
    "verify": "pnpm run test:packages && pnpm run build:packages && pnpm run build:showcase && pnpm run release:check && pnpm run pack:dry-run"
  },
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": "24.x"
  },
  "engineStrict": true,
  "dependencies": {
    "@angular/aria": "catalog:frontend",
    "@angular/cdk": "catalog:frontend",
    "@angular/common": "catalog:frontend",
    "@angular/compiler": "catalog:frontend",
    "@angular/core": "catalog:frontend",
    "@angular/forms": "catalog:frontend",
    "@angular/platform-browser": "catalog:frontend",
    "@angular/router": "catalog:frontend",
    "@tanstack/angular-table": "catalog:frontend",
    "marked": "^18.0.5",
    "ngx-markdown": "22.0.0",
    "prismjs": "^1.30.0",
    "rxjs": "catalog:frontend",
    "tslib": "catalog:shared"
  },
  "devDependencies": {
    "@angular/build": "catalog:frontend-dev",
    "@angular/cli": "catalog:frontend-dev",
    "@angular/compiler-cli": "catalog:frontend-dev",
    "@nx/angular": "catalog:frontend-dev",
    "@nx/js": "catalog:shared-dev",
    "@playwright/test": "catalog:frontend-dev",
    "jsdom": "catalog:frontend-dev",
    "ng-advanced-table": "workspace:*",
    "ng-advanced-table-locales": "workspace:*",
    "ng-advanced-table-ui": "workspace:*",
    "ng-advanced-table-utils": "workspace:*",
    "ng-packagr": "catalog:frontend-dev",
    "nx": "catalog:shared-dev",
    "prettier": "catalog:shared-dev",
    "typescript": "catalog:shared-dev",
    "vitest": "catalog:shared-dev"
  }
}
