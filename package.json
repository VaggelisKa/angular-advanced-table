{
  "name": "angular-advanced-table",
  "version": "0.0.0",
  "description": "Workspace for the ng-advanced-table Angular libraries and showcase application.",
  "scripts": {
    "ng": "ng",
    "nx": "nx",
    "start": "nx serve showcase",
    "build": "nx build showcase",
    "build:showcase": "nx build showcase",
    "build:packages": "nx run-many -t build -p ng-advanced-table,ng-advanced-table-ui,ng-advanced-table-utils",
    "watch": "nx build showcase --watch --configuration development",
    "test": "nx test showcase",
    "test:packages": "nx run-many -t test -p ng-advanced-table,ng-advanced-table-ui,ng-advanced-table-utils",
    "release:check": "nx release plan:check --base=${NX_BASE:-main} --head=${NX_HEAD:-HEAD} && nx release --dry-run",
    "release": "nx release",
    "pack:dry-run": "npm pack --dry-run ./dist/libs/ng-advanced-table && npm pack --dry-run ./dist/libs/ng-advanced-table-ui && npm pack --dry-run ./dist/libs/ng-advanced-table-utils",
    "verify": "npm run test:packages && npm run build:packages && npm run build:showcase && npm run release:check && npm run pack:dry-run"
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "libs/ng-advanced-table",
    "libs/ng-advanced-table-ui",
    "libs/ng-advanced-table-utils"
  ],
  "dependencies": {
    "@angular/cdk": "^21.2.6",
    "@angular/aria": "^21.2.6",
    "@angular/common": "^21.2.8",
    "@angular/compiler": "^21.2.8",
    "@angular/core": "^21.2.8",
    "@angular/forms": "^21.2.8",
    "@angular/platform-browser": "^21.2.8",
    "@angular/router": "^21.2.8",
    "@tanstack/angular-table": "^8.21.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.8",
    "@angular/cli": "^21.2.8",
    "@angular/compiler-cli": "^21.2.8",
    "@nx/angular": "^22.7.0",
    "@nx/js": "^22.7.0",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "nx": "^22.7.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
