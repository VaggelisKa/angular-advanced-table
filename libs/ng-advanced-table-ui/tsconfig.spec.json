/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "../../",
    "outDir": "../../out-tsc/spec",
    "types": ["vitest/globals"],
    "paths": {
      "ng-advanced-table": [
        "libs/ng-advanced-table/src/public-api.ts",
        "dist/libs/ng-advanced-table"
      ],
      "ng-advanced-table-ui": [
        "libs/ng-advanced-table-ui/src/public-api.ts",
        "dist/libs/ng-advanced-table-ui"
      ],
      "ng-advanced-table-utils": [
        "libs/ng-advanced-table-utils/src/public-api.ts",
        "dist/libs/ng-advanced-table-utils"
      ]
    }
  },
  "include": ["src/**/*.d.ts", "src/**/*.spec.ts"]
}
