{
  "name": "ng-advanced-table-locales",
  "version": "1.1.0",
  "description": "Built-in locale registry and provider helpers for ng-advanced-table.",
  "typings": "src/public-api.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VaggelisKa/angular-advanced-table.git",
    "directory": "libs/ng-advanced-table-locales"
  },
  "homepage": "https://github.com/VaggelisKa/angular-advanced-table/tree/main/libs/ng-advanced-table-locales#readme",
  "bugs": {
    "url": "https://github.com/VaggelisKa/angular-advanced-table/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "angular",
    "table",
    "i18n",
    "localization",
    "accessibility"
  ],
  "peerDependencies": {
    "@angular/core": "catalog:peers"
  },
  "dependencies": {
    "tslib": "catalog:shared"
  },
  "sideEffects": false,
  "nx": {
    "name": "ng-advanced-table-locales",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "projectType": "library",
    "prefix": "nat",
    "sourceRoot": "libs/ng-advanced-table-locales/src",
    "tags": [
      "type:lib",
      "scope:public"
    ],
    "targets": {
      "build": {
        "executor": "@nx/angular:package",
        "outputs": [
          "{workspaceRoot}/dist/libs/ng-advanced-table-locales"
        ],
        "options": {
          "project": "libs/ng-advanced-table-locales/ng-package.json",
          "tsConfig": "libs/ng-advanced-table-locales/tsconfig.lib.prod.json"
        },
        "configurations": {
          "production": {
            "tsConfig": "libs/ng-advanced-table-locales/tsconfig.lib.prod.json"
          },
          "development": {
            "tsConfig": "libs/ng-advanced-table-locales/tsconfig.lib.json"
          }
        },
        "defaultConfiguration": "production"
      },
      "test-build": {
        "executor": "@angular/build:ng-packagr",
        "options": {
          "project": "libs/ng-advanced-table-locales/ng-package.json",
          "tsConfig": "libs/ng-advanced-table-locales/tsconfig.lib.json"
        },
        "configurations": {
          "production": {
            "tsConfig": "libs/ng-advanced-table-locales/tsconfig.lib.prod.json"
          },
          "development": {
            "tsConfig": "libs/ng-advanced-table-locales/tsconfig.lib.json"
          }
        },
        "defaultConfiguration": "development"
      },
      "test": {
        "executor": "@angular/build:unit-test",
        "options": {
          "buildTarget": "ng-advanced-table-locales:test-build:development",
          "tsConfig": "libs/ng-advanced-table-locales/tsconfig.spec.json"
        }
      },
      "strip-nx": {
        "executor": "nx:run-commands"
      },
      "nx-release-publish": {
        "executor": "@nx/js:release-publish"
      }
    }
  }
}
