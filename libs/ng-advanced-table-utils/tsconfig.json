/* Project solution file. Build/test options live in the referenced configs; shared options come from tsconfig.base.json. */
{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    /* Source-first path mappings (tsconfig.base.json) resolve sibling libs to their src, which sits
       outside the per-lib inferred rootDir. Anchor rootDir at the workspace root so the editor's
       type-check program doesn't raise TS6059. ng-packagr manages its own output for the real build. */
    "rootDir": "../.."
  },
  "files": [],
  "include": [],
  "references": [{ "path": "./tsconfig.lib.json" }, { "path": "./tsconfig.spec.json" }]
}
