{
  "name": "ng-advanced-table-utils",
  "version": "1.2.0",
  "description": "Optional companion helpers for ng-advanced-table, including render metrics tooling.",
  "typings": "../../dist/libs/ng-advanced-table-utils/types/ng-advanced-table-utils.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VaggelisKa/angular-advanced-table.git",
    "directory": "libs/ng-advanced-table-utils"
  },
  "homepage": "https://github.com/VaggelisKa/angular-advanced-table/tree/main/libs/ng-advanced-table-utils#readme",
  "bugs": {
    "url": "https://github.com/VaggelisKa/angular-advanced-table/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "angular",
    "table",
    "render-metrics",
    "performance",
    "tanstack-table"
  ],
  "peerDependencies": {
    "@angular/core": "catalog:peers",
    "@tanstack/angular-table": "catalog:peers"
  },
  "dependencies": {
    "ng-advanced-table-locales": "*",
    "tslib": "catalog:shared"
  },
  "sideEffects": false,
  "nx": {
    "name": "ng-advanced-table-utils",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "projectType": "library",
    "prefix": "nat",
    "sourceRoot": "libs/ng-advanced-table-utils/src",
    "tags": [
      "type:lib",
      "scope:public"
    ],
    "targets": {
      "build": {
        "executor": "@nx/angular:package",
        "outputs": [
          "{workspaceRoot}/dist/libs/ng-advanced-table-utils"
        ],
        "options": {
          "project": "libs/ng-advanced-table-utils/ng-package.json"
        },
        "configurations": {
          "production": {
            "tsConfig": "libs/ng-advanced-table-utils/tsconfig.lib.prod.json"
          },
          "development": {
            "tsConfig": "libs/ng-advanced-table-utils/tsconfig.lib.json"
          }
        },
        "defaultConfiguration": "production"
      },
      "test-build": {
        "executor": "@angular/build:ng-packagr",
        "options": {
          "project": "libs/ng-advanced-table-utils/ng-package.json"
        },
        "configurations": {
          "production": {
            "tsConfig": "libs/ng-advanced-table-utils/tsconfig.lib.prod.json"
          },
          "development": {
            "tsConfig": "libs/ng-advanced-table-utils/tsconfig.lib.json"
          }
        },
        "defaultConfiguration": "development"
      },
      "test": {
        "executor": "@angular/build:unit-test",
        "options": {
          "buildTarget": "ng-advanced-table-utils:test-build:development",
          "tsConfig": "libs/ng-advanced-table-utils/tsconfig.spec.json"
        }
      },
      "strip-nx": {
        "executor": "nx:run-commands"
      },
      "nx-release-publish": {
        "executor": "@nx/js:release-publish"
      }
    }
  }
}
