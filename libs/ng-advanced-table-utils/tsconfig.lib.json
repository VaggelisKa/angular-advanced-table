{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../../out-tsc/lib-utils",
    "declaration": true,
    "declarationMap": true,
    "types": [],
    "paths": {
      "ng-advanced-table-locales": [
