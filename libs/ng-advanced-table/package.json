{
  "name": "ng-advanced-table",
  "version": "1.2.0",
  "description": "Signals-first Angular data table built on TanStack Table — core primitives plus composable UI, utilities, and i18n via subpath entry points (ng-advanced-table/ui, /utils, /locale).",
  "typings": "src/index.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VaggelisKa/angular-advanced-table.git",
    "directory": "libs/ng-advanced-table"
  },
  "homepage": "https://github.com/VaggelisKa/angular-advanced-table/tree/main/libs/ng-advanced-table#readme",
  "bugs": {
    "url": "https://github.com/VaggelisKa/angular-advanced-table/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "angular",
    "signals",
    "table",
    "data-table",
    "tanstack-table",
    "ui",
    "i18n",
    "accessibility"
  ],
  "peerDependencies": {
    "@angular/cdk": "catalog:peers",
    "@angular/aria": "catalog:peers",
    "@angular/common": "catalog:peers",
    "@angular/core": "catalog:peers",
    "@tanstack/angular-table": "catalog:peers"
  },
  "dependencies": {
    "tslib": "catalog:shared"
  },
  "sideEffects": false,
  "exports": {
    "./package.json": {
      "default": "./package.json"
    },
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./locale": {
      "types": "./locale/index.ts",
      "default": "./locale/index.ts"
    },
    "./ui": {
      "types": "./ui/index.ts",
      "default": "./ui/index.ts"
    },
    "./utils": {
      "types": "./utils/index.ts",
      "default": "./utils/index.ts"
    }
  },
  "nx": {
    "name": "ng-advanced-table",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "projectType": "library",
    "prefix": "nat",
    "sourceRoot": "libs/ng-advanced-table",
    "tags": [
      "type:lib",
      "scope:public"
    ],
    "targets": {
      "build": {
        "executor": "@angular/build:ng-packagr",
        "options": {
          "project": "libs/ng-advanced-table/ng-package.json"
        },
        "configurations": {
          "production": {
            "tsConfig": "libs/ng-advanced-table/tsconfig.lib.prod.json"
          },
          "development": {
            "tsConfig": "libs/ng-advanced-table/tsconfig.lib.json"
          }
        },
        "defaultConfiguration": "production"
      },
      "lint": {
        "executor": "nx:noop"
      },
      "stylelint": {
        "executor": "nx:noop"
      },
      "strip-nx": {
        "executor": "nx:run-commands"
      },
      "nx-release-publish": {
        "executor": "@nx/js:release-publish"
      }
    }
  }
}
